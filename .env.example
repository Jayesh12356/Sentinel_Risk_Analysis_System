OPENROUTER_API_KEY=sk-or-v1-your-key-here
NEWSAPI_KEY=your-newsapi-key-here
SENTINEL_PRIMARY_MODEL=google/gemini-2.5-flash-lite
SENTINEL_EMBEDDING_MODEL=google/gemini-embedding-001
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sentinel_signals
DEMO_MODE=true
LOG_LEVEL=INFO

# --- LLM Provider Switching ---
# "openrouter" (default) or "groq"
LLM_PROVIDER=openrouter
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Company Profile (Level 2) ---
COMPANY_PROFILE_PATH=data/company_profile.json

# --- Memory (Level 3) ---
QDRANT_MEMORY_COLLECTION=sentinel_memory

# --- Alerts (Level 3) ---
ALERT_DEMO_MODE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=
ALERT_EMAIL_TO=yourname@gmail.com
SLACK_WEBHOOK_URL=
ALERTS_ENABLED=true

# --- Prompt Optimisation (Level 4) ---
QDRANT_PROMPTS_COLLECTION=sentinel_prompts
QUALITY_THRESHOLD=0.70
OPTIMISER_ENABLED=true
OPTIMISER_MIN_RUNS=3

# --- Human Feedback (Level 5) ---
QDRANT_FEEDBACK_COLLECTION=sentinel_feedback
FEEDBACK_BASE_URL=http://localhost:8000
FEEDBACK_WINDOW_DAYS=30
FEEDBACK_MIN_ENTRIES=5

# --- Multi-Tenant (Level 6) ---
ACTIVE_TENANT=default
TENANTS_DIR=data/tenants
QDRANT_SHARED_COLLECTION=sentinel_shared_patterns

# --- Predictive Risk Intelligence (Level 7) ---
FORECAST_ENABLED=true
FORECAST_ALERT_THRESHOLD=0.80
FORECAST_MIN_PROBABILITY=0.40
FORECAST_MIN_HISTORY=5
FORECAST_HORIZON_DEFAULT=H72

# --- Autonomous Actions (Level 8) ---
ACTION_DEMO_MODE=true
ACTION_AUTO_THRESHOLD=0.85
ACTION_APPROVAL_THRESHOLD=0.60
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=SEC
PAGERDUTY_INTEGRATION_KEY=
ACTION_WEBHOOK_URL=http://httpbin.org/post

# --- Negotiation (Level 9) ---
SERPAPI_KEY=
NEGOTIATION_ENABLED=true
NEGOTIATION_AUTO_SEND=false
NEGOTIATION_TIMEOUT_HOURS=24
REPLY_POLL_INTERVAL_MINUTES=30
NEGOTIATION_MAX_ALTERNATIVES=5

# --- Meta + Governance (Level 10) ---
META_RUN_INTERVAL_RUNS=5
META_ENABLED=true
AB_TEST_ENABLED=true
AB_TEST_MIN_RUNS=10
GOVERNANCE_ENABLED=true
OVERRIDE_RULES_PATH=data/override_rules.json
